---
import MobileMenuToggle from "@astrojs/starlight/components/MobileMenuToggle.astro";

const { hasSidebar } = Astro.locals.starlightRoute;
const currentPath = Astro.url.pathname;
const docGroups = [
  { label: "Home", href: "/" },
  { label: "User Manual (EN)", href: "/manual/en/" },
  { label: "User Manual (RU)", href: "/manual/ru/" },
  { label: "User Manual (ZH)", href: "/manual/zh/" },
  { label: "Developer Docs", href: "/developer/" },
];

const isGroupActive = (href: string) => {
  if (href === "/") {
    return currentPath === "/";
  }

  return (
    currentPath === href ||
    currentPath.startsWith(href) ||
    (href === "/manual/zh/" && currentPath.startsWith("/用户手册/"))
  );
};

const currentGroup = docGroups.find(({ href }) => isGroupActive(href)) ?? docGroups[0];
---

<div class="page sl-flex">
  <header class="header"><slot name="header" /></header>
  {
    hasSidebar && (
      <nav class="sidebar print:hidden" aria-label={Astro.locals.t("sidebarNav.accessibleLabel")}>
        <MobileMenuToggle />
        <div id="starlight__sidebar" class="sidebar-pane">
          <div class="dropdown-wrapper">
            <details class="group-switcher">
              <summary>
                <span>{currentGroup.label}</span>
                <span aria-hidden="true">▾</span>
              </summary>
              <div class="group-menu" aria-label="Documentation groups">
                {docGroups.map(({ label, href }) => (
                  <a class:list={["group-link", isGroupActive(href) && "is-active"]} href={href}>
                    {label}
                  </a>
                ))}
              </div>
            </details>
          </div>
          <div class="sidebar-content sl-flex">
            <slot name="sidebar" />
          </div>
        </div>
      </nav>
    )
  }
  <div class="main-frame"><slot /></div>
</div>

<script>
  // scroll current page on sidebar into view
  window.addEventListener("load", () => {
    document
      .querySelector(`#starlight__sidebar a[aria-current="page"]`)
      ?.scrollIntoView({ behavior: "smooth", block: "center" });
  });
</script>

<style>
  .page {
    flex-direction: column;
    min-height: 100vh;
  }

  .header {
    z-index: var(--sl-z-index-navbar);
    position: fixed;
    inset-inline-start: 0;
    inset-block-start: 0;
    width: 100%;
    height: var(--sl-nav-height);
    border-bottom: 1px solid var(--sl-color-hairline-shade);
    padding: var(--sl-nav-pad-y) var(--sl-nav-pad-x);
    padding-inline-end: var(--sl-nav-pad-x);
    background-color: var(--sl-color-bg-nav);
  }

  :global([data-has-sidebar]) .header {
    padding-inline-start: calc(var(--sl-nav-gap) + var(--sl-nav-pad-x) + var(--sl-menu-button-size));
  }

  /* change MobileMenuToggle position */
  .sidebar :global(starlight-menu-button button) {
    inset-inline-start: var(--sl-nav-pad-x);
  }

  .sidebar-pane {
    display: flex;
    flex-direction: column;
    visibility: var(--sl-sidebar-visibility, hidden);
    position: fixed;
    z-index: var(--sl-z-index-menu);
    inset-block: var(--sl-nav-height) 0;
    inset-inline-start: 0;
    width: 100%;
    background-color: var(--sl-color-black);
  }

  :global([aria-expanded="true"]) ~ .sidebar-pane {
    --sl-sidebar-visibility: visible;
  }

  .dropdown-wrapper {
    padding: var(--sl-sidebar-pad-x);
    background-color: var(--sl-color-black);
    border-bottom: 1px solid var(--sl-color-hairline-light);
  }

  .group-switcher {
    position: relative;
  }

  .group-switcher summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    list-style: none;
    cursor: pointer;
    font-size: var(--sl-text-sm);
    font-weight: 600;
    color: var(--sl-color-white);
    border: 1px solid var(--sl-color-hairline-shade);
    border-radius: 0.5rem;
    background-color: var(--sl-color-black);
    padding: 0.55rem 0.65rem;
  }

  .group-switcher summary::-webkit-details-marker {
    display: none;
  }

  .group-menu {
    margin-top: 0.35rem;
    border: 1px solid var(--sl-color-hairline-shade);
    border-radius: 0.5rem;
    background-color: var(--sl-color-black);
    overflow: hidden;
  }

  .group-link {
    display: block;
    padding: 0.5rem 0.65rem;
    text-decoration: none;
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-sm);
  }

  .group-link:hover {
    color: var(--sl-color-white);
    background-color: var(--sl-color-gray-6);
  }

  .group-link.is-active {
    color: var(--sl-color-white);
    background-color: color-mix(in oklch, var(--sl-color-text-accent) 20%, transparent);
  }

  .sidebar-content {
    height: 100%;
    padding: 1rem var(--sl-sidebar-pad-x) 0;
    flex-direction: column;
    gap: 1rem;
    overflow-y: auto;
  }

  /* highlight sidebar items with accent color */
  .sidebar-content :global(a:not([aria-current="page"]):hover) {
    color: var(--sl-color-accent-high);
  }
  .main-frame :global(.right-sidebar a:hover) {
    color: var(--sl-color-accent-high);
  }

  @media (min-width: 50rem) {
    .sidebar-content::after {
      content: "";
      padding-bottom: 1px;
    }
  }

  .main-frame {
    padding-top: calc(var(--sl-nav-height) + var(--sl-mobile-toc-height));
    padding-inline-start: var(--sl-content-inline-start);
  }

  @media (min-width: 50rem) {
    :global([data-has-sidebar]) .header {
      padding-inline-start: var(--sl-nav-pad-x);
    }
    .sidebar-pane {
      --sl-sidebar-visibility: visible;
      width: var(--sl-sidebar-width);
      background-color: var(--sl-color-bg-sidebar);
      border-inline-end: 1px solid var(--sl-color-hairline-shade);
    }
    .dropdown-wrapper {
      background-color: var(--sl-color-bg-sidebar);
    }
  }
</style>
